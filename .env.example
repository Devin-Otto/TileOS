# Copy this file to `.env.local` for local development, or set the same values
# in your hosting provider's secure environment settings before deployment.
#
# Never commit real secrets to git.

PORT=9273
HOST=127.0.0.1
APP_TITLE=TileOS
NODE_ENV=development
TILEOS_PUBLIC_URL=http://127.0.0.1:9273
TILEOS_BASE_PATH=
TILEOS_DATA_ROOT=./data

# Required for admin login and signed session cookies.
ADMIN_PASSWORD=replace-me
SESSION_SECRET=replace-me

# Gemini keys stay server-side only. This is optional for local proof-of-life
# and fallback demo mode. Provide one or more keys, comma-separated, when you
# want live Gemini generation.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# Optional overrides for CI or unusual hosting:
# - TILEOS_SECURE_COOKIES=true forces Secure cookies.
# - TILEOS_SECURE_COOKIES=false disables them.
# By default TileOS enables Secure cookies automatically when NODE_ENV=production
# and TILEOS_PUBLIC_URL is https.
TILEOS_SECURE_COOKIES=

# Set this only for CI or release checks when you need to ignore local dotenv files.
TILEOS_DISABLE_DOTENV=
